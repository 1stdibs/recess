@Library('shared-jenkins-libraries@master') _

pipeline {
    agent { label 'standard_node' }

    options {
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 2, unit: 'HOURS')
    }

    stages {
        stage('Deploy') {
            steps {
                sh '''#!/bin/bash
set -e
yarn install
JENKINS_BUILD=true ./deploy.sh
'''
            }
        }
    }
}
